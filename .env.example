# ============================================
# Stax AI Tutor — Environment Variables
# Copy to .env.local and fill in real values
# ============================================

# ---------- App ----------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Stax AI Tutor

# ---------- MongoDB ----------
# MongoDB Atlas connection string OR local mongodb://localhost:27017
MONGODB_URI=mongodb://localhost:27017/stax-tutor
MONGODB_DB_NAME=stax-tutor

# ---------- NextAuth (Authentication) ----------
# Generate via: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-strong-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — for social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- JWT ----------
JWT_SECRET=replace-with-different-strong-secret
JWT_EXPIRES_IN=7d

# ---------- Google Gemini AI ----------
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ---------- Judge0 (Code Execution) ----------
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-rapidapi-key
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# ---------- Upstash Redis (Rate Limit + Cache) ----------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ---------- PayU (Payments) ----------
PAYU_MERCHANT_KEY=your-merchant-key
PAYU_MERCHANT_SALT=your-merchant-salt
PAYU_BASE_URL=https://test.payu.in/_payment
PAYU_SUCCESS_URL=http://localhost:3000/payments/success
PAYU_FAILURE_URL=http://localhost:3000/payments/failure

# ---------- HuggingFace (Optional AI Backup) ----------
HUGGINGFACE_API_KEY=

# ---------- Logging ----------
LOG_LEVEL=info
# Set to 'pretty' in dev for readable logs, 'json' in prod
LOG_FORMAT=pretty
